# Environment variables for the access-manager Spring Boot app.
#
# For LOCAL DEVELOPMENT you don't need this file at all — the local stack
# in `compose.local.yaml` sets these directly on the access-manager
# service. This file documents the variables for PRODUCTION deployment
# (cbhcloud or any other Kubernetes / Docker host).

# ── Web ────────────────────────────────────────────────────────────────
PORT=8080

# ── Postgres (DuckLake catalogs + access manager bookkeeping) ──────────
# Hostname the access-manager pod can reach. The same Postgres holds:
#   - the access manager's own tables (datasets, groups, dataset_grants,
#     key_user_mapping)
#   - one DuckLake catalog database per dataset (dl_<bucket>)
POSTGRES_HOST=ducklake-catalog
POSTGRES_DB=ducklake
POSTGRES_ADMIN_USER=ducklake
POSTGRES_ADMIN_PASSWORD=change-me

# Public hostname baked into generated DuckDB scripts. This is the host
# the *student's* environment uses to reach Postgres — it may differ
# from POSTGRES_HOST if cluster-internal and external DNS names differ.
POSTGRES_PUBLIC_HOST=ducklake-catalog.example.kth.se

# ── Garage (S3-compatible object store) ────────────────────────────────
# Admin API URL — used by the access-manager to manage buckets and keys.
GARAGE_ADMIN_URL=http://ducklake-garage:3900
GARAGE_ADMIN_TOKEN=change-me

# S3 endpoint baked into generated DuckDB scripts. Students point their
# DuckDB at this. Use the public-facing URL.
GARAGE_S3_ENDPOINT=ducklake-garage.example.kth.se:443
GARAGE_S3_REGION=garage

# ── Keycloak / OAuth2 ──────────────────────────────────────────────────
# The issuer URL Spring expects in the JWT `iss` claim. Must match what
# Keycloak emits — for KTH cloud that's the IAM realm URL below.
KEYCLOAK_ISSUER_URI=https://iam.cloud.cbh.kth.se/realms/cloud
