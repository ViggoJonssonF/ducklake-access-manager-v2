{
  "realm": "cloud",
  "enabled": true,
  "displayName": "DuckLake (local dev)",
  "registrationAllowed": false,
  "rememberMe": true,
  "verifyEmail": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": false,
  "accessTokenLifespan": 3600,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "clients": [
    {
      "clientId": "ducklake",
      "name": "DuckLake Access Manager",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "frontchannelLogout": false,
      "rootUrl": "http://localhost:8080",
      "baseUrl": "/",
      "redirectUris": [
        "http://localhost:8080/*",
        "http://localhost:8080"
      ],
      "webOrigins": [
        "http://localhost:8080",
        "+"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:8080/*##http://localhost:8080"
      },
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "roles",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ],
      "protocolMappers": [
        {
          "name": "audience-ducklake",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "ducklake",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "roles": {
    "client": {
      "ducklake": [
        {
          "name": "admin",
          "description": "Can manage buckets, datasets, groups, grants, and any user's keys"
        }
      ]
    }
  },
  "users": [
    {
      "username": "admin@local",
      "email": "admin@local",
      "firstName": "Local",
      "lastName": "Admin",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": false
        }
      ],
      "clientRoles": {
        "ducklake": ["admin"]
      },
      "realmRoles": ["default-roles-cloud"]
    },
    {
      "username": "student@local",
      "email": "student@local",
      "firstName": "Local",
      "lastName": "Student",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "student",
          "temporary": false
        }
      ],
      "realmRoles": ["default-roles-cloud"]
    },
    {
      "username": "student2@local",
      "email": "student2@local",
      "firstName": "Local",
      "lastName": "Student2",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "student",
          "temporary": false
        }
      ],
      "realmRoles": ["default-roles-cloud"]
    }
  ]
}
